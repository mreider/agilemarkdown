# Binaries for programs and plugins
*.exe
*.dll
*.so
*.dylib

# Test binary, build with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Project-local glide cache, RE: https://github.com/Masterminds/glide/issues/736
.glide/

.idea/

# Local Claude Code state. The shipped artifacts (skills, hooks,
# settings.json) stay tracked; everything else under .claude/ is
# local-only.
.claude/settings.local.json
.claude/projects/
.claude/cache/
.claude/state/
.claude/conversations/

# Build artifacts
agilemarkdown
agilemarkdown_bash_autocomplete
